# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# --- Required ---
# DeepSeek API key (https://platform.deepseek.com) — powers the bot.
DEEPSEEK_API_KEY=sk-your-deepseek-key

# The ONLY WhatsApp number allowed to use the bot, E.164 format.
# (Keep it locked to your own number while testing; open up for production.)
ALLOWED_NUMBER=+923000000000

# Admin dashboard password (the username is always "admin"). Use a strong value.
ADMIN_PASS=change-this-to-a-strong-password

# --- Optional ---
# Only needed if you switch the model to an OpenRouter model.
OPENROUTER_API_KEY=

# openclaw gateway auth token. Leave blank to auto-generate on first run.
GATEWAY_TOKEN=
